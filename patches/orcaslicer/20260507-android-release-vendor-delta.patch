+            vertex_map[vertex_idx] = int(out.vertices.size());
+            out.vertices.emplace_back(m_vertices[vertex_idx].v);
+        }
+        indices[i] = vertex_map[vertex_idx];
+    }
+    out.indices.emplace_back(indices);
