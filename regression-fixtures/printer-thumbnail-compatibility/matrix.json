{
  "schema_version": 1,
  "policy": {
    "parity_target": "OrcaSlicer thumbnail metadata compatibility without adding hidden work to normal slicing",
    "status_meanings": {
      "proven_live": "Validated against a real printer host or UI consumer and backed by an automated gate.",
      "gated": "Validated by local/device automation, but not yet proven on a live printer host.",
      "source_supported": "Orca/MobileSlicer source paths are present, but no full generated-output gate exists yet.",
      "pending_live_validation": "Expected compatible, but must not be claimed as supported until a live host or fixture proves it.",
      "not_supported": "Known unsupported behavior."
    },
    "required_release_gates": [
      "fluidd-thumbnail-metadata",
      "sliced-3mf-metadata",
      "multi-plate-sliced-3mf-metadata",
      "orca-thumbnail-reference-matrix"
    ],
    "required_verification_gates": [
      "orca-metadata-benchmark"
    ]
  },
