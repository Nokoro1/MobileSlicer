      "id": "sliced-3mf-metadata",
      "kind": "3mf",
      "model": "regression-fixtures/slicing/mobileslicer_test_cube.stl",
      "paths": {
        "mobile_3mf": "regression-fixtures/orca-metadata/mobile/simple-cube.gcode.3mf",
