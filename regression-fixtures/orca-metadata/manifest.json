          "Metadata/plate_1_small.png",
          "Metadata/plate_no_light_1.png",
          "Metadata/top_1.png",
          "Metadata/pick_1.png"
        ],
        "expect_3mf_relationship_targets": [
          "/Metadata/plate_1.png",
          "/Metadata/plate_1_small.png"
        ],
        "expect_3mf_bbox_json": [
          "Metadata/plate_1.json"
        ],
        "require_distinct_3mf_thumbnail_entries": true,
        "require_3mf_thumbnail_visuals": true,
        "validate_orca_3mf_thumbnails": false,
        "validate_orca_3mf_relationship_targets": false
      }
    },
    {
      "id": "multi-filament-gcode",
      "kind": "gcode",
      "notes": "MobileSlicer automation loads the same deterministic STL twice with extruder IDs 1 and 2 to validate Orca object-level tool assignment and emitted toolchange metadata. Desktop Orca CLI reference generation cannot assign per-object extruders without a project fixture, so this case validates the MobileSlicer export contract directly.",
      "model": "regression-fixtures/slicing/mobileslicer_test_cube.stl",
      "paths": {
        "mobile_gcode": "regression-fixtures/orca-metadata/mobile/multi-filament.gcode"
      },
      "mobile_capture": {
        "verify_android_label": "multi-filament",
        "config_overrides": {
          "thumbnails": "128x128",
          "thumbnails_format": "PNG",
          "filament_type": [
            "PLA",
            "PLA"
          ],
          "filament_settings_id": [
            "Generic PLA A",
            "Generic PLA B"
          ],
          "filament_colour": [
            "#F2754E",
            "#4EA3F2"
          ],
          "filament_diameter": [
            1.75,
            1.75
          ],
          "nozzle_temperature_initial_layer": [
            210,
            210
          ],
          "nozzle_temperature": [
            210,
            210
          ],
          "filament_max_volumetric_speed": [
            50,
            50
          ],
          "flush_multiplier": [
            1,
            1
          ],
          "flush_volumes_matrix": "0,0,0,0,0,0,0,0"
        },
        "automation_two_filament_objects": true
      },
      "expectations": {
        "expect_thumbnails": [
          "thumbnail:128x128"
        ],
        "require_gcode_thumbnail_visuals": true,
        "require_gcode_thumbnail_antialias": true,
        "require_print_time": true,
        "require_filament": true,
        "require_toolchange": true,
        "require_stripped_hash_match": false
      }
    }
  ]
}
