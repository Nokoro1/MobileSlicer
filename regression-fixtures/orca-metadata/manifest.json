{
  "schema_version": 1,
  "orca_reference": {
    "status": "cli-metadata-plus-source-thumbnail-contract",
    "required_for_strict_gate": true,
    "notes": "Official OrcaSlicer CLI calls export_gcode with a null thumbnail callback, so CLI references validate print-time and filament metadata while thumbnail block parity is validated from Orca source contracts and MobileSlicer outputs."
  },
  "cases": [
    {
      "id": "simple-cube-png-gcode",
      "kind": "gcode",
      "model": "regression-fixtures/slicing/mobileslicer_test_cube.stl",
      "paths": {
        "mobile_gcode": "regression-fixtures/orca-metadata/mobile/simple-cube-png.gcode",
        "orca_gcode": "regression-fixtures/orca-metadata/references/simple-cube-png.gcode"
      },
      "mobile_capture": {
        "verify_android_label": "simple-cube-png",
        "config_overrides": {
          "thumbnails": "128x128",
          "thumbnails_format": "PNG",
          "filament_type": "PLA"
        }
      },
      "expectations": {
        "expect_thumbnails": [
          "thumbnail:128x128"
        ],
        "require_gcode_thumbnail_visuals": true,
        "require_gcode_thumbnail_antialias": true,
        "require_print_time": true,
        "require_filament": true,
        "validate_orca_thumbnails": false,
        "require_stripped_hash_match": false
      }
    },
    {
      "id": "qidi-q2-legacy-png-gcode",
      "kind": "gcode",
      "model": "regression-fixtures/slicing/mobileslicer_test_cube.stl",
      "paths": {
        "mobile_gcode": "regression-fixtures/orca-metadata/mobile/qidi-q2-legacy-png.gcode",
        "orca_gcode": "regression-fixtures/orca-metadata/references/qidi-q2-legacy-png.gcode"
      },
      "mobile_capture": {
        "verify_android_label": "qidi-q2-legacy-png",
        "config_overrides": {
          "thumbnails": "150x150",
          "thumbnails_format": "PNG",
          "filament_type": "PLA"
        },
        "notes": "Mobile automation currently forces the normalized Orca request. Desktop reference generation must use the actual Qidi Q2 profile legacy thumbnail_size path."
      },
      "expectations": {
        "expect_thumbnails": [
          "thumbnail:150x150"
        ],
        "forbid_thumbnail_tags": [
          "gimage",
          "simage"
        ],
        "require_gcode_thumbnail_visuals": true,
        "require_gcode_thumbnail_antialias": true,
        "require_print_time": true,
        "require_filament": true,
        "validate_orca_thumbnails": false,
        "require_stripped_hash_match": false
      }
    },
