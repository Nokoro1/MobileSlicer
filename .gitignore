# Local tooling and editor state
.android-sdk/
.android-native-deps/
.idea/

# Local-only project notes.
/README/
!/README/
/README/*
!/README/plans/
/README/plans/*
!/README/plans/MODEL_SEARCH_IMPORT_PLAN.md

# Website deployment cache.
/Website/.wrangler/

# Upstream metadata and generated dependency folders that do not belong in the
# public Android source tree.
vendor/orcaslicer/.devcontainer/
vendor/orcaslicer/.github/
vendor/orcaslicer/resources/**/node_modules/

# Root build outputs
/build/

# Android/Gradle generated outputs
/android-app/.gradle/
/android-app/.kotlin/
/android-app/app/build/
/android-app/app/.cxx/
/android-app/app/src/main/assets/adi-registration.properties
/android-app/local.properties
/android-app/release-signing.properties
hs_err*.log
__pycache__/
*.py[cod]

# Generated native dependency build trees
/engine-wrapper/orca-android-libslic3r/android-deps-build/
/engine-wrapper/orca-android-libslic3r/android-deps-install/
/engine-wrapper/orca-android-libslic3r/android-probe-build/

# Local artifact holding areas
/_quarantine/
/artifacts/
/tmp/
/scanner-audits/
/tools/
/result.json
*.apk
*.gcode

# OS noise
.DS_Store
Thumbs.db
